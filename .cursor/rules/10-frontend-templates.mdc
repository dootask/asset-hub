## 表单处理模板

### 完整表单组件
```typescript
import { useForm } from 'react-hook-form'
import { zodResolver } from '@hookform/resolvers/zod'
import { z } from 'zod'
import { useTranslation } from 'react-i18next'
import { createAsset } from '@/api/asset'
import { modalSuccess, modalError } from '@dootask/tools'
import { Button } from '@/components/ui/button'
import { Input } from '@/components/ui/input'
import { Label } from '@/components/ui/label'

const assetSchema = z.object({
  name: z.string().min(2, '名称至少2个字符'),
  type: z.string().min(1, '请选择资产类型'),
  price: z.number().positive('价格必须大于0'),
  purchaseDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/, '日期格式错误'),
})

type AssetFormData = z.infer<typeof assetSchema>

export const AssetForm = () => {
  const { t } = useTranslation()
  const {
    register,
    handleSubmit,
    formState: { errors, isSubmitting },
    reset,
  } = useForm<AssetFormData>({
    resolver: zodResolver(assetSchema),
  })

  const onSubmit = async (data: AssetFormData) => {
    try {
      await createAsset(data)
      await modalSuccess(t('asset.createSuccess'))
      reset()
    } catch (error) {
      console.error('Create asset failed:', error)
    }
  }

  return (
    <form onSubmit={handleSubmit(onSubmit)} className="space-y-4">
      <div>
        <Label htmlFor="name">{t('asset.name')}</Label>
        <Input
          id="name"
          {...register('name')}
          className={errors.name ? 'border-red-500' : ''}
        />
        {errors.name && (
          <p className="text-sm text-red-500 mt-1">{errors.name.message}</p>
        )}
      </div>

      <div>
        <Label htmlFor="type">{t('asset.type')}</Label>
        <select
          id="type"
          {...register('type')}
          className="w-full rounded-md border p-2"
        >
          <option value="">请选择</option>
          <option value="fixed">固定资产</option>
          <option value="it">IT设备</option>
          <option value="office">办公用品</option>
        </select>
        {errors.type && (
          <p className="text-sm text-red-500 mt-1">{errors.type.message}</p>
        )}
      </div>

      <div>
        <Label htmlFor="price">{t('asset.price')}</Label>
        <Input
          id="price"
          type="number"
          step="0.01"
          {...register('price', { valueAsNumber: true })}
          className={errors.price ? 'border-red-500' : ''}
        />
        {errors.price && (
          <p className="text-sm text-red-500 mt-1">{errors.price.message}</p>
        )}
      </div>

      <div>
        <Label htmlFor="purchaseDate">{t('asset.purchaseDate')}</Label>
        <Input
          id="purchaseDate"
          type="date"
          {...register('purchaseDate')}
          className={errors.purchaseDate ? 'border-red-500' : ''}
        />
        {errors.purchaseDate && (
          <p className="text-sm text-red-500 mt-1">{errors.purchaseDate.message}</p>
        )}
      </div>

      <Button type="submit" disabled={isSubmitting}>
        {isSubmitting ? t('common.submitting') : t('common.submit')}
      </Button>
    </form>
  )
}
```

## Hooks 模板

### 数据获取 Hook
```typescript
import { useState, useEffect } from 'react'

export function useFetchData<T>(
  fetchFn: () => Promise<T>,
  deps: any[] = []
) {
  const [data, setData] = useState<T | null>(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState<Error | null>(null)

  useEffect(() => {
    const fetchData = async () => {
      try {
        setLoading(true)
        const result = await fetchFn()
        setData(result)
        setError(null)
      } catch (err) {
        setError(err as Error)
      } finally {
        setLoading(false)
      }
    }
    fetchData()
  }, deps)

  return { data, loading, error, refetch: () => fetchData() }
}
```

### DooTask 用户信息 Hook
```typescript
import { useState, useEffect } from 'react'
import { getUserInfo } from '@dootask/tools'
import type { DooTaskUserInfo } from '@dootask/tools'

export function useCurrentUser() {
  const [user, setUser] = useState<DooTaskUserInfo | null>(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState<Error | null>(null)

  useEffect(() => {
    const fetchUser = async () => {
      try {
        const userInfo = await getUserInfo()
        setUser(userInfo)
      } catch (err) {
        setError(err as Error)
      } finally {
        setLoading(false)
      }
    }
    fetchUser()
  }, [])

  return { user, loading, error }
}
```

### 防抖 Hook
```typescript
import { useEffect, useState } from 'react'

export function useDebounce<T>(value: T, delay: number = 500): T {
  const [debouncedValue, setDebouncedValue] = useState<T>(value)

  useEffect(() => {
    const handler = setTimeout(() => {
      setDebouncedValue(value)
    }, delay)

    return () => {
      clearTimeout(handler)
    }
  }, [value, delay])

  return debouncedValue
}
```

