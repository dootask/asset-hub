## 工作流3：实现审批流程

**场景**：为某个操作添加审批流程（如"资产采购审批"）

### 核心步骤

#### 1. 设计审批流程数据结构

```typescript
// server/src/types/index.ts
export interface ApprovalFlow {
  id: number
  name: string
  type: string  // 操作类型: purchase, borrow, transfer, etc.
  steps: ApprovalStep[]
}

export interface ApprovalStep {
  step: number
  approverType: 'user' | 'role' | 'manager'
  approverId?: number  // 如果是具体用户
  roleId?: number      // 如果是角色
  required: boolean    // 是否必须
}

export interface ApprovalRecord {
  id: number
  operationId: number  // 关联的操作ID
  operationType: string
  currentStep: number
  status: 'pending' | 'approved' | 'rejected'
  approvals: ApprovalDetail[]
}

export interface ApprovalDetail {
  step: number
  approverId: number
  status: 'pending' | 'approved' | 'rejected'
  comment: string
  approvedAt?: string
}
```

#### 2. 创建审批表

```typescript
// server/src/models/db.ts
db.exec(`
  CREATE TABLE IF NOT EXISTS approval_flows (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    type TEXT NOT NULL,
    steps TEXT NOT NULL,  -- JSON 格式存储步骤
    created_at TEXT NOT NULL
  )
`)

db.exec(`
  CREATE TABLE IF NOT EXISTS approval_records (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    operation_id INTEGER NOT NULL,
    operation_type TEXT NOT NULL,
    flow_id INTEGER NOT NULL,
    current_step INTEGER NOT NULL DEFAULT 1,
    status TEXT NOT NULL DEFAULT 'pending',
    created_at TEXT NOT NULL,
    FOREIGN KEY (flow_id) REFERENCES approval_flows(id)
  )
`)

db.exec(`
  CREATE TABLE IF NOT EXISTS approval_details (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    record_id INTEGER NOT NULL,
    step INTEGER NOT NULL,
    approver_id INTEGER NOT NULL,
    status TEXT NOT NULL DEFAULT 'pending',
    comment TEXT,
    approved_at TEXT,
    FOREIGN KEY (record_id) REFERENCES approval_records(id)
  )
`)
```

#### 3. 实现审批服务

```typescript
// server/src/services/approvalService.ts

export function createApprovalRecord(
  operationId: number,
  operationType: string,
  flowId: number
): ApprovalRecord {
  // 1. 获取审批流程
  const flow = getApprovalFlow(flowId)
  
  // 2. 创建审批记录
  const stmt = db.prepare(`
    INSERT INTO approval_records (operation_id, operation_type, flow_id, current_step, status, created_at)
    VALUES (?, ?, ?, ?, ?, ?)
  `)
  const now = new Date().toISOString()
  const result = stmt.run(operationId, operationType, flowId, 1, 'pending', now)
  const recordId = result.lastInsertRowid as number
  
  // 3. 为每个步骤创建审批详情
  const detailStmt = db.prepare(`
    INSERT INTO approval_details (record_id, step, approver_id, status)
    VALUES (?, ?, ?, ?)
  `)
  for (const step of flow.steps) {
    const approverId = resolveApproverId(step)  // 根据规则解析审批人ID
    detailStmt.run(recordId, step.step, approverId, 'pending')
  }
  
  // 4. 发送通知给第一步审批人
  notifyApprover(recordId, 1)
  
  return getApprovalRecord(recordId)!
}

export function submitApproval(
  recordId: number,
  step: number,
  approverId: number,
  status: 'approved' | 'rejected',
  comment: string
): ApprovalRecord {
  // 1. 更新审批详情
  const stmt = db.prepare(`
    UPDATE approval_details 
    SET status = ?, comment = ?, approved_at = ?
    WHERE record_id = ? AND step = ? AND approver_id = ?
  `)
  const now = new Date().toISOString()
  stmt.run(status, comment, now, recordId, step, approverId)
  
  // 2. 如果拒绝，整个流程结束
  if (status === 'rejected') {
    updateApprovalRecordStatus(recordId, 'rejected')
    notifyApplicant(recordId, 'rejected')
    return getApprovalRecord(recordId)!
  }
  
  // 3. 如果通过，检查是否还有下一步
  const record = getApprovalRecord(recordId)!
  const nextStep = step + 1
  const hasNextStep = record.approvals.some(a => a.step === nextStep)
  
  if (hasNextStep) {
    // 进入下一步
    updateApprovalRecordStep(recordId, nextStep)
    notifyApprover(recordId, nextStep)
  } else {
    // 所有步骤完成，审批通过
    updateApprovalRecordStatus(recordId, 'approved')
    notifyApplicant(recordId, 'approved')
    executePostApprovalAction(record)  // 执行审批后操作（如更新资产状态）
  }
  
  return getApprovalRecord(recordId)!
}
```

#### 4. 前端审批界面

```typescript
// ui/src/pages/approval/detail.tsx

import { useState, useEffect } from 'react'
import { useParams } from 'react-router-dom'
import { useTranslation } from 'react-i18next'
import { getApprovalDetail, submitApproval } from '@/api/approval'
import { modalSuccess, modalError } from '@dootask/tools'

export default function ApprovalDetailPage() {
  const { id } = useParams()
  const { t } = useTranslation()
  const [approval, setApproval] = useState(null)
  const [comment, setComment] = useState('')

  useEffect(() => {
    fetchApprovalDetail()
  }, [id])

  const fetchApprovalDetail = async () => {
    try {
      const result = await getApprovalDetail(Number(id))
      setApproval(result)
    } catch (error) {
      await modalError(t('approval.fetchFailed'))
    }
  }

  const handleApprove = async () => {
    try {
      await submitApproval(Number(id), {
        status: 'approved',
        comment,
      })
      await modalSuccess(t('approval.approveSuccess'))
      fetchApprovalDetail()
    } catch (error) {
      console.error('Approve failed:', error)
    }
  }

  const handleReject = async () => {
    if (!comment) {
      await modalError(t('approval.commentRequired'))
      return
    }
    try {
      await submitApproval(Number(id), {
        status: 'rejected',
        comment,
      })
      await modalSuccess(t('approval.rejectSuccess'))
      fetchApprovalDetail()
    } catch (error) {
      console.error('Reject failed:', error)
    }
  }

  if (!approval) {
    return <div>Loading...</div>
  }

  return (
    <div>
      <h1>{t('approval.title')}</h1>
      {/* 显示审批详情 */}
      <textarea
        value={comment}
        onChange={(e) => setComment(e.target.value)}
        placeholder={t('approval.commentPlaceholder')}
      />
      <button onClick={handleApprove}>{t('approval.approve')}</button>
      <button onClick={handleReject}>{t('approval.reject')}</button>
    </div>
  )
}
```

