**2.4 创建控制器**
```typescript
// server/src/controllers/inventoryController.ts

import { Context } from 'koa'
import { z } from 'zod'
import * as inventoryService from '../services/inventoryService'
import { success, error } from '../utils/response'

const createSchema = z.object({
  name: z.string().min(2),
  type: z.string(),
  startDate: z.string(),
  assigneeId: z.number(),
})

export async function getList(ctx: Context) {
  const result = await inventoryService.getInventoryList(ctx.query)
  ctx.body = success(result)
}

export async function getDetail(ctx: Context) {
  const id = parseInt(ctx.params.id, 10)
  const inventory = await inventoryService.getInventoryById(id)
  if (!inventory) {
    ctx.body = error('盘点任务不存在', 'NOT_FOUND')
    return
  }
  ctx.body = success(inventory)
}

export async function create(ctx: Context) {
  try {
    const data = createSchema.parse(ctx.request.body)
    const inventory = await inventoryService.createInventory({
      ...data,
      createdBy: ctx.state.user.id,
    })
    ctx.body = success(inventory, '创建成功')
  } catch (err) {
    if (err instanceof z.ZodError) {
      ctx.body = error('参数验证失败', 'VALIDATION_ERROR', err.errors)
    } else {
      throw err
    }
  }
}

// ... 其他方法
```

