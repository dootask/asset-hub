## 工作流5：数据库迁移

**场景**：需要修改数据库表结构

### 迁移步骤

#### 1. 编写迁移脚本
```typescript
// server/src/migrations/001_add_asset_location.ts

export function up(db: Database) {
  db.exec(`
    ALTER TABLE assets ADD COLUMN location TEXT;
  `)
  db.exec(`
    CREATE INDEX IF NOT EXISTS idx_assets_location ON assets(location);
  `)
}

export function down(db: Database) {
  // SQLite 不支持 DROP COLUMN，需要重建表
  db.exec(`
    CREATE TABLE assets_new AS SELECT 
      id, name, type, status, price, purchase_date, 
      description, owner_id, created_by, created_at, 
      updated_at, deleted_at
    FROM assets;
  `)
  db.exec(`DROP TABLE assets;`)
  db.exec(`ALTER TABLE assets_new RENAME TO assets;`)
}
```

#### 2. 执行迁移
```typescript
// server/src/models/migrations.ts

import { db } from './db'

const migrations = [
  require('./migrations/001_add_asset_location'),
  // ... 更多迁移
]

export function runMigrations() {
  // 创建迁移记录表
  db.exec(`
    CREATE TABLE IF NOT EXISTS migrations (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL UNIQUE,
      applied_at TEXT NOT NULL
    )
  `)

  // 执行未应用的迁移
  for (const migration of migrations) {
    const name = migration.name || 'unnamed'
    const exists = db.prepare(
      'SELECT 1 FROM migrations WHERE name = ?'
    ).get(name)

    if (!exists) {
      migration.up(db)
      db.prepare(
        'INSERT INTO migrations (name, applied_at) VALUES (?, ?)'
      ).run(name, new Date().toISOString())
      console.log(`Migration applied: ${name}`)
    }
  }
}
```

#### 3. 在应用启动时运行迁移
```typescript
// server/src/index.ts

import { runMigrations } from './models/migrations'

async function bootstrap() {
  await initDatabase()
  await runMigrations()  // 执行迁移
  // ... 启动服务器
}
```

