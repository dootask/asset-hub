# 后端开发 - 核心规范

## 技术栈

- **Node.js**: 20.x LTS
- **Koa**: 轻量级 Web 框架
- **TypeScript**: 类型安全
- **better-sqlite3**: 同步 SQLite 驱动（高性能）
- **Zod**: 数据验证
- **Pino**: 结构化日志

## 目录结构

```
server/
├── src/
│   ├── index.ts              # 应用入口
│   ├── app.ts                # Koa 应用配置
│   ├── config.ts             # 配置管理
│   ├── routes/               # 路由（index.ts + 各模块.ts）
│   ├── controllers/          # 控制器（参数验证、响应处理）
│   ├── services/             # 业务逻辑（数据库操作）
│   ├── models/               # 数据模型（db.ts + schema.ts）
│   ├── middleware/           # 中间件（auth.ts, errorHandler.ts, logger.ts）
│   ├── utils/                # 工具函数（response.ts, logger.ts）
│   └── types/                # TypeScript 类型
├── database/                 # SQLite 数据库文件
├── .env
├── package.json
└── tsconfig.json
```

## 统一响应格式

### 工具函数
```typescript
// src/utils/response.ts
export interface SuccessResponse<T = any> {
  success: true
  data: T
  message?: string
}

export interface ErrorResponse {
  success: false
  error: string
  code: string
  details?: any
}

export function success<T>(data: T, message?: string): SuccessResponse<T> {
  return { success: true, data, message }
}

export function error(message: string, code: string, details?: any): ErrorResponse {
  return { success: false, error: message, code, details }
}
```

## 控制器模式

### 标准控制器结构
```typescript
// src/controllers/assetController.ts
import { Context } from 'koa'
import { z } from 'zod'
import * as assetService from '../services/assetService'
import { success, error } from '../utils/response'

const querySchema = z.object({
  page: z.string().optional().transform(v => v ? parseInt(v, 10) : 1),
  pageSize: z.string().optional().transform(v => v ? parseInt(v, 10) : 20),
  status: z.enum(['all', 'in-use', 'idle']).optional(),
})

export async function getList(ctx: Context) {
  try {
    const params = querySchema.parse(ctx.query)
    const result = await assetService.getAssetList(params)
    ctx.body = success(result)
  } catch (err) {
    if (err instanceof z.ZodError) {
      ctx.body = error('参数验证失败', 'VALIDATION_ERROR', err.errors)
    } else {
      throw err
    }
  }
}
```

## 服务层模式

### 数据库操作规范
```typescript
// src/services/assetService.ts
import { db } from '../models/db'

export interface AssetListParams {
  page: number
  pageSize: number
  status?: string
}

export function getAssetList(params: AssetListParams) {
  const { page, pageSize, status } = params
  const offset = (page - 1) * pageSize

  let query = 'SELECT * FROM assets WHERE 1=1'
  const queryParams: any[] = []

  if (status && status !== 'all') {
    query += ' AND status = ?'
    queryParams.push(status)
  }

  // 计算总数
  const countQuery = query.replace('SELECT *', 'SELECT COUNT(*) as count')
  const { count } = db.prepare(countQuery).get(...queryParams) as { count: number }

  // 分页查询
  query += ' ORDER BY created_at DESC LIMIT ? OFFSET ?'
  queryParams.push(pageSize, offset)
  const list = db.prepare(query).all(...queryParams)

  return { list, total: count, page, pageSize }
}
```

## 路由配置

### 路由定义
```typescript
// src/routes/asset.ts
import Router from 'koa-router'
import * as assetController from '../controllers/assetController'
import { authMiddleware } from '../middleware/auth'

const router = new Router({ prefix: '/api/assets' })

router.use(authMiddleware)

router.get('/', assetController.getList)
router.get('/:id', assetController.getDetail)
router.post('/', assetController.create)
router.put('/:id', assetController.update)
router.delete('/:id', assetController.remove)

export default router
```

## 中间件

### 错误处理（必需）
```typescript
// src/middleware/errorHandler.ts
import { Context, Next } from 'koa'
import { error } from '../utils/response'

export async function errorHandler(ctx: Context, next: Next) {
  try {
    await next()
  } catch (err: any) {
    const status = err.status || 500
    const message = err.message || '服务器内部错误'
    const code = err.code || 'INTERNAL_ERROR'

    ctx.status = status
    ctx.body = error(message, code)
    
    console.error('Request error:', err)
  }
}
```

### 认证中间件（必需）
```typescript
// src/middleware/auth.ts
import { Context, Next } from 'koa'
import { error } from '../utils/response'

export async function authMiddleware(ctx: Context, next: Next) {
  const token = ctx.headers.authorization?.replace('Bearer ', '')

  if (!token) {
    ctx.status = 401
    ctx.body = error('未授权', 'UNAUTHORIZED')
    return
  }

  try {
    // TODO: 验证 token 并获取用户信息
    ctx.state.user = { id: 1, email: 'user@example.com' }
    await next()
  } catch (err) {
    ctx.status = 401
    ctx.body = error('Token 无效', 'INVALID_TOKEN')
  }
}
```

## 数据库管理

### 初始化数据库
```typescript
// src/models/db.ts
import Database from 'better-sqlite3'
import path from 'path'

const DB_PATH = process.env.DB_PATH || path.join(__dirname, '../../database/asset-hub.db')

export const db = new Database(DB_PATH)
db.pragma('journal_mode = WAL')

export function initDatabase() {
  // 创建资产表
  db.exec(`
    CREATE TABLE IF NOT EXISTS assets (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL,
      type TEXT NOT NULL,
      status TEXT NOT NULL DEFAULT 'idle',
      price REAL NOT NULL,
      purchase_date TEXT NOT NULL,
      owner_id INTEGER,
      created_by INTEGER NOT NULL,
      created_at TEXT NOT NULL,
      updated_at TEXT
    )
  `)

  // 创建索引
  db.exec(`
    CREATE INDEX IF NOT EXISTS idx_assets_status ON assets(status);
    CREATE INDEX IF NOT EXISTS idx_assets_type ON assets(type);
  `)
}

export function closeDatabase() {
  db.close()
}
```

## 类型定义

```typescript
// src/types/index.ts
export interface Asset {
  id: number
  name: string
  type: string
  status: 'idle' | 'in-use' | 'maintenance' | 'scrapped'
  price: number
  purchase_date: string
  owner_id?: number
  created_by: number
  created_at: string
  updated_at?: string
}

export type AssetInsert = Omit<Asset, 'id' | 'created_at' | 'updated_at'>
