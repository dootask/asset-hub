```

## 组件规范

### 命名和导出
```typescript
// ✅ 正确：使用 named export
export const AssetCard: FC<AssetCardProps> = ({ ... }) => { ... }

// ❌ 错误：不要用 default export
export default function AssetCard() { ... }
```

### Props 定义
```typescript
// ✅ 正确：使用 interface，命名为 组件名+Props
interface AssetCardProps {
  id: number
  name: string
  onEdit?: (id: number) => void
}
```

## API 调用规范

### 统一客户端
```typescript
// src/api/client.ts
import axios from 'axios'
import { getUserToken, modalError } from '@dootask/tools'

export const apiClient = axios.create({
  baseURL: '/api',
  timeout: 30000,
})

// 请求拦截器：添加 token
apiClient.interceptors.request.use(async (config) => {
  const token = await getUserToken()
  if (token) config.headers.Authorization = `Bearer ${token}`
  return config
})

// 响应拦截器：统一错误处理
apiClient.interceptors.response.use(
  (response) => response.data,
  async (error) => {
    await modalError(error.response?.data?.error || '请求失败')
    return Promise.reject(error)
  }
)
```

### API 模块结构
```typescript
// src/api/asset.ts
export interface Asset { ... }
export interface AssetListParams { ... }
export interface AssetListResponse { ... }

export const getAssetList = async (params?: AssetListParams) => {
  return apiClient.get<AssetListResponse>('/assets', { params })
}
```

## 状态管理

### Zustand Store 模式
```typescript
// src/stores/assetStore.ts
import { create } from 'zustand'

interface AssetState {
  selectedAsset: Asset | null
  filterStatus: string
  setSelectedAsset: (asset: Asset | null) => void
  setFilterStatus: (status: string) => void
  reset: () => void
}

export const useAssetStore = create<AssetState>((set) => ({
  selectedAsset: null,
  filterStatus: 'all',
  setSelectedAsset: (asset) => set({ selectedAsset: asset }),
  setFilterStatus: (status) => set({ filterStatus: status }),
  reset: () => set({ selectedAsset: null, filterStatus: 'all' }),
}))
```

