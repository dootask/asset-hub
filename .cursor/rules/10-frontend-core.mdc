## DooTask 集成

### 应用初始化（必须）
```typescript
// src/App.tsx
import { useEffect, useState } from 'react'
import { useTranslation } from 'react-i18next'
import { appReady, getThemeName, getLanguageName, UnsupportedError } from '@dootask/tools'

export default function App() {
  const { i18n } = useTranslation()
  const [isReady, setIsReady] = useState(false)

  useEffect(() => {
    const init = async () => {
      try {
        await appReady()
        
        const theme = await getThemeName()
        document.documentElement.classList.toggle('dark', theme === 'dark')
        
        const lang = await getLanguageName()
        await i18n.changeLanguage(lang.includes('zh') ? 'zh' : 'en')
        
        setIsReady(true)
      } catch (error) {
        if (error instanceof UnsupportedError) {
          console.warn('Not in DooTask environment')
          setIsReady(true)
        }
      }
    }
    init()
  }, [i18n])

  if (!isReady) return <div>Loading...</div>
  return <Router />
}
```

