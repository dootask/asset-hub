本文档提供详细的后端代码模板，按需参考。

## 完整 CRUD 示例

### Controller 完整示例
```typescript
// src/controllers/assetController.ts
import { Context } from 'koa'
import { z } from 'zod'
import * as assetService from '../services/assetService'
import { success, error } from '../utils/response'

const createSchema = z.object({
  name: z.string().min(2, '名称至少2个字符'),
  type: z.string().min(1, '请选择资产类型'),
  price: z.number().positive('价格必须大于0'),
  purchaseDate: z.string().regex(/^\d{4}-\d{2}-\d{2}$/, '日期格式错误'),
})

const updateSchema = createSchema.partial()

const querySchema = z.object({
  page: z.string().optional().transform(v => v ? parseInt(v, 10) : 1),
  pageSize: z.string().optional().transform(v => v ? parseInt(v, 10) : 20),
  status: z.enum(['all', 'in-use', 'idle', 'scrapped']).optional(),
  search: z.string().optional(),
})

export async function getList(ctx: Context) {
  try {
    const params = querySchema.parse(ctx.query)
    const result = await assetService.getAssetList(params)
    ctx.body = success(result)
  } catch (err) {
    if (err instanceof z.ZodError) {
      ctx.body = error('参数验证失败', 'VALIDATION_ERROR', err.errors)
    } else {
      throw err
    }
  }
}

export async function getDetail(ctx: Context) {
  const id = parseInt(ctx.params.id, 10)
  if (isNaN(id)) {
    ctx.body = error('无效的资产ID', 'INVALID_ID')
    return
  }

  const asset = await assetService.getAssetById(id)
  if (!asset) {
    ctx.body = error('资产不存在', 'NOT_FOUND')
    return
  }

  ctx.body = success(asset)
}

export async function create(ctx: Context) {
  try {
    const data = createSchema.parse(ctx.request.body)
    const userId = ctx.state.user.id
    
    const asset = await assetService.createAsset({
      ...data,
      createdBy: userId,
    })
    
    ctx.body = success(asset, '创建成功')
  } catch (err) {
    if (err instanceof z.ZodError) {
      ctx.body = error('参数验证失败', 'VALIDATION_ERROR', err.errors)
    } else {
      throw err
    }
  }
}

export async function update(ctx: Context) {
  const id = parseInt(ctx.params.id, 10)
  if (isNaN(id)) {
    ctx.body = error('无效的资产ID', 'INVALID_ID')
    return
  }

  try {
    const data = updateSchema.parse(ctx.request.body)
    const asset = await assetService.updateAsset(id, data)
    
    if (!asset) {
      ctx.body = error('资产不存在', 'NOT_FOUND')
      return
    }
    
    ctx.body = success(asset, '更新成功')
  } catch (err) {
    if (err instanceof z.ZodError) {
      ctx.body = error('参数验证失败', 'VALIDATION_ERROR', err.errors)
    } else {
      throw err
    }
  }
}

export async function remove(ctx: Context) {
  const id = parseInt(ctx.params.id, 10)
  if (isNaN(id)) {
    ctx.body = error('无效的资产ID', 'INVALID_ID')
    return
  }

  const deleted = await assetService.deleteAsset(id)
  if (!deleted) {
    ctx.body = error('资产不存在', 'NOT_FOUND')
    return
  }

  ctx.body = success(null, '删除成功')
}

export async function batchDelete(ctx: Context) {
  const { ids } = ctx.request.body as { ids: number[] }
  
  if (!Array.isArray(ids) || ids.length === 0) {
    ctx.body = error('请提供要删除的资产ID列表', 'INVALID_PARAMS')
    return
  }

  const count = await assetService.batchDeleteAssets(ids)
  ctx.body = success({ count }, `成功删除 ${count} 个资产`)
}
```

### Service 完整示例
```typescript
// src/services/assetService.ts
import { db } from '../models/db'
import { Asset, AssetInsert, AssetUpdate } from '../types'

export interface AssetListParams {
  page: number
  pageSize: number
  status?: string
  search?: string
}

export function getAssetList(params: AssetListParams) {
  const { page, pageSize, status, search } = params
  const offset = (page - 1) * pageSize

  let query = 'SELECT * FROM assets WHERE 1=1'
  const queryParams: any[] = []

  if (status && status !== 'all') {
    query += ' AND status = ?'
    queryParams.push(status)
  }

  if (search) {
    query += ' AND (name LIKE ? OR code LIKE ?)'
    const searchPattern = `%${search}%`
    queryParams.push(searchPattern, searchPattern)
  }

  const countQuery = query.replace('SELECT *', 'SELECT COUNT(*) as count')
  const countResult = db.prepare(countQuery).get(...queryParams) as { count: number }
  const total = countResult.count

  query += ' ORDER BY created_at DESC LIMIT ? OFFSET ?'
  queryParams.push(pageSize, offset)
  
  const list = db.prepare(query).all(...queryParams) as Asset[]

  return { list, total, page, pageSize }
}

export function getAssetById(id: number): Asset | undefined {
  const stmt = db.prepare('SELECT * FROM assets WHERE id = ?')
  return stmt.get(id) as Asset | undefined
}

export function createAsset(data: AssetInsert): Asset {
  const stmt = db.prepare(`
    INSERT INTO assets (name, type, price, purchase_date, status, created_by, created_at)
    VALUES (?, ?, ?, ?, ?, ?, ?)
  `)
  
  const now = new Date().toISOString()
  const result = stmt.run(
    data.name,
    data.type,
    data.price,
    data.purchaseDate,
    'idle',
    data.createdBy,
    now
  )

  const asset = getAssetById(result.lastInsertRowid as number)
  if (!asset) throw new Error('Failed to create asset')
  return asset
}

export function updateAsset(id: number, data: AssetUpdate): Asset | null {
  const existing = getAssetById(id)
  if (!existing) return null

  const fields: string[] = []
  const values: any[] = []

  if (data.name !== undefined) {
    fields.push('name = ?')
    values.push(data.name)
  }
  if (data.type !== undefined) {
    fields.push('type = ?')
    values.push(data.type)
  }
  if (data.price !== undefined) {
    fields.push('price = ?')
    values.push(data.price)
  }
  if (data.status !== undefined) {
    fields.push('status = ?')
    values.push(data.status)
  }

  if (fields.length === 0) return existing

  fields.push('updated_at = ?')
  values.push(new Date().toISOString())
  values.push(id)

  const stmt = db.prepare(`UPDATE assets SET ${fields.join(', ')} WHERE id = ?`)
  stmt.run(...values)

  return getAssetById(id)!
}

export function deleteAsset(id: number): boolean {
  const stmt = db.prepare('DELETE FROM assets WHERE id = ?')
  const result = stmt.run(id)
  return result.changes > 0
}

export function batchDeleteAssets(ids: number[]): number {
  const placeholders = ids.map(() => '?').join(',')
  const stmt = db.prepare(`DELETE FROM assets WHERE id IN (${placeholders})`)
  const result = stmt.run(...ids)
  return result.changes
}
```

## 数据库事务

```typescript
// 使用事务批量创建
export function batchCreateAssets(assets: AssetInsert[]): Asset[] {
  const transaction = db.transaction((assetList: AssetInsert[]) => {
    const results: Asset[] = []
    for (const asset of assetList) {
      const result = createAsset(asset)
      results.push(result)
    }
    return results
  })

  return transaction(assets)
}
```

