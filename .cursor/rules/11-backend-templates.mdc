## 文件上传处理

```typescript
// src/controllers/uploadController.ts
import { Context } from 'koa'
import { File } from 'formidable'
import fs from 'fs'
import path from 'path'
import { success, error } from '../utils/response'

export async function upload(ctx: Context) {
  const file = ctx.request.files?.file as File
  
  if (!file) {
    ctx.body = error('请选择文件', 'NO_FILE')
    return
  }

  // 检查文件类型
  const allowedTypes = ['image/jpeg', 'image/png', 'image/webp']
  if (!allowedTypes.includes(file.mimetype || '')) {
    ctx.body = error('只支持 JPG/PNG/WebP 格式', 'INVALID_FILE_TYPE')
    return
  }

  // 检查文件大小（5MB）
  if (file.size > 5 * 1024 * 1024) {
    ctx.body = error('文件大小不能超过 5MB', 'FILE_TOO_LARGE')
    return
  }

  // 生成文件名
  const ext = path.extname(file.originalFilename || '')
  const filename = `${Date.now()}-${Math.random().toString(36).slice(2)}${ext}`
  const uploadDir = path.join(__dirname, '../../uploads')
  const filepath = path.join(uploadDir, filename)

  // 确保上传目录存在
  if (!fs.existsSync(uploadDir)) {
    fs.mkdirSync(uploadDir, { recursive: true })
  }

  // 移动文件
  fs.renameSync(file.filepath, filepath)

  ctx.body = success({
    url: `/uploads/${filename}`,
    filename: file.originalFilename,
    size: file.size,
  }, '上传成功')
}
```

## 数据库迁移

```typescript
// src/models/migrations.ts
import { db } from './db'

interface Migration {
  name: string
  up: (db: any) => void
  down: (db: any) => void
}

const migrations: Migration[] = [
  {
    name: '001_add_asset_location',
    up: (db) => {
      db.exec('ALTER TABLE assets ADD COLUMN location TEXT')
      db.exec('CREATE INDEX IF NOT EXISTS idx_assets_location ON assets(location)')
    },
    down: (db) => {
      // SQLite 不支持 DROP COLUMN，需要重建表
    },
  },
]

export function runMigrations() {
  db.exec(`
    CREATE TABLE IF NOT EXISTS migrations (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      name TEXT NOT NULL UNIQUE,
      applied_at TEXT NOT NULL
    )
  `)

  for (const migration of migrations) {
    const exists = db.prepare('SELECT 1 FROM migrations WHERE name = ?').get(migration.name)

    if (!exists) {
      migration.up(db)
      db.prepare('INSERT INTO migrations (name, applied_at) VALUES (?, ?)').run(
        migration.name,
        new Date().toISOString()
      )
      console.log(`Migration applied: ${migration.name}`)
    }
  }
}
```

